# =============================================================================
# Trigger.dev Self-Hosted Configuration Template
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Then generate secrets:
#   openssl rand -hex 16   (for MAGIC_LINK_SECRET, SESSION_SECRET, ENCRYPTION_KEY)
#   openssl rand -hex 32   (for PROVIDER_SECRET, COORDINATOR_SECRET)
# =============================================================================

# ---------------------------------------------------------------------------
# Core Settings
# ---------------------------------------------------------------------------
PORT=3030
REMIX_APP_PORT=3030
NODE_ENV=production
RUNTIME_PLATFORM=docker-compose
V3_ENABLED=true
INTERNAL_OTEL_TRACE_DISABLED=1
INTERNAL_OTEL_TRACE_LOGGING_ENABLED=0

# ---------------------------------------------------------------------------
# Domain Configuration
# ---------------------------------------------------------------------------
# For local testing, leave commented (defaults to http://localhost:3040)
# For production with reverse proxy, uncomment and set your domain:
# TRIGGER_PROTOCOL=https
# TRIGGER_DOMAIN=trigger.yourdomain.com

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_USER=trigger
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=trigger
DATABASE_HOST=postgres:5432
# NOTE: Variable interpolation (${VAR}) does NOT work in env_file.
# You must hardcode the full connection string here.
DATABASE_URL=postgresql://trigger:CHANGE_ME_USE_STRONG_PASSWORD@postgres:5432/trigger
DIRECT_URL=postgresql://trigger:CHANGE_ME_USE_STRONG_PASSWORD@postgres:5432/trigger

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TLS_DISABLED=true

# ---------------------------------------------------------------------------
# Secrets (MUST change before production!)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 16
MAGIC_LINK_SECRET=CHANGE_ME_RUN_openssl_rand_hex_16
SESSION_SECRET=CHANGE_ME_RUN_openssl_rand_hex_16
ENCRYPTION_KEY=CHANGE_ME_RUN_openssl_rand_hex_16

# Generate with: openssl rand -hex 32
PROVIDER_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32
COORDINATOR_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32
ELECTRIC_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32

# ---------------------------------------------------------------------------
# Concurrency Limits
# ---------------------------------------------------------------------------
# Lower these if your server runs out of memory
DEFAULT_ORG_EXECUTION_CONCURRENCY_LIMIT=300
DEFAULT_ENV_EXECUTION_CONCURRENCY_LIMIT=100

# ---------------------------------------------------------------------------
# Worker Settings
# ---------------------------------------------------------------------------
HTTP_SERVER_PORT=9020
COORDINATOR_HOST=127.0.0.1
COORDINATOR_PORT=9020

# ---------------------------------------------------------------------------
# Email Configuration
# ---------------------------------------------------------------------------
# Without email configured, magic links print to webapp container logs.
# View them with: docker compose logs -f webapp
#
# Option A: Mailpit (local testing - included in docker-compose)
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# FROM_EMAIL=trigger@localhost
# REPLY_TO_EMAIL=noreply@localhost
#
# Option B: Resend (production)
# FROM_EMAIL=noreply@yourdomain.com
# REPLY_TO_EMAIL=support@yourdomain.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
#
# Alert emails (separate config):
# ALERT_FROM_EMAIL=alerts@yourdomain.com
# ALERT_RESEND_API_KEY=re_xxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Access Control
# ---------------------------------------------------------------------------
# Restrict who can sign up (regex patterns):
# WHITELISTED_EMAILS="admin@yourdomain\.com|team@yourdomain\.com"
#
# Grant admin panel access:
# ADMIN_EMAILS="admin@yourdomain\.com"
#
# GitHub OAuth (optional):
# AUTH_GITHUB_CLIENT_ID=
# AUTH_GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Registry (for deploying trigger tasks)
# ---------------------------------------------------------------------------
# Images pushed to: host/namespace/project:version
# DEPLOY_REGISTRY_HOST=docker.io
# DEPLOY_REGISTRY_NAMESPACE=your-dockerhub-username
# REGISTRY_HOST=${DEPLOY_REGISTRY_HOST}
# REGISTRY_NAMESPACE=${DEPLOY_REGISTRY_NAMESPACE}

# ---------------------------------------------------------------------------
# Docker Compose Overrides
# ---------------------------------------------------------------------------
# Bind addresses: 127.0.0.1 = localhost only (reverse proxy)
#                 0.0.0.0   = all interfaces (direct access)
WEBAPP_PUBLISH_IP=127.0.0.1
DOCKER_PUBLISH_IP=127.0.0.1

# Host port mappings (change if you have port conflicts)
WEBAPP_HOST_PORT=3040
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6389
ELECTRIC_HOST_PORT=3061
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# Image version pinning
TRIGGER_IMAGE_TAG=v3
POSTGRES_IMAGE_TAG=16
REDIS_IMAGE_TAG=7
ELECTRIC_IMAGE_TAG=latest
