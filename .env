# =============================================================================
# Trigger.dev Self-Hosted Configuration
# =============================================================================
#
# SECURITY: This file contains secrets. Set file permissions to 600:
#   chmod 600 .env
#
# Regenerate secrets before real production deployment:
#   openssl rand -hex 16   (for MAGIC_LINK_SECRET, SESSION_SECRET, ENCRYPTION_KEY)
#   openssl rand -hex 32   (for PROVIDER_SECRET, COORDINATOR_SECRET)
#
# =============================================================================

# ---------------------------------------------------------------------------
# Core Settings
# ---------------------------------------------------------------------------
PORT=3030
REMIX_APP_PORT=3030
NODE_ENV=production
RUNTIME_PLATFORM=docker-compose
V3_ENABLED=true
INTERNAL_OTEL_TRACE_DISABLED=1
INTERNAL_OTEL_TRACE_LOGGING_ENABLED=0

# ---------------------------------------------------------------------------
# Domain Configuration
# ---------------------------------------------------------------------------
# For production with reverse proxy, uncomment and set your domain:
# TRIGGER_PROTOCOL=https
# TRIGGER_DOMAIN=trigger.yourdomain.com

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_USER=trigger
POSTGRES_PASSWORD=2237501ac5729499b3cf30f8af061b1017efab45a9df2a54
POSTGRES_DB=trigger
DATABASE_HOST=postgres:5432
DATABASE_URL=postgresql://trigger:2237501ac5729499b3cf30f8af061b1017efab45a9df2a54@postgres:5432/trigger
DIRECT_URL=postgresql://trigger:2237501ac5729499b3cf30f8af061b1017efab45a9df2a54@postgres:5432/trigger

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TLS_DISABLED=true

# ---------------------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------------------
MAGIC_LINK_SECRET=31312c1afc7b937ea3d24554e4c19caa
SESSION_SECRET=9f0931b9821e325888a9b94b27f77ab8
ENCRYPTION_KEY=87c6f90b5837b4869c48a5855a8d1115

PROVIDER_SECRET=e0106694e5cb02e416740768be21734064f6dab7823dd2d4748c5ef8b2e7b4eb
COORDINATOR_SECRET=b9d304f720767839297296781b71340398573bd618dd13cf237bc80675a1012a
ELECTRIC_SECRET=25940c708802aa4c608ecf8e2878ab7591580b58dd1e701ff0da0b4cd68e558e

# ---------------------------------------------------------------------------
# Concurrency Limits
# ---------------------------------------------------------------------------
DEFAULT_ORG_EXECUTION_CONCURRENCY_LIMIT=300
DEFAULT_ENV_EXECUTION_CONCURRENCY_LIMIT=100

# ---------------------------------------------------------------------------
# Worker Settings
# ---------------------------------------------------------------------------
HTTP_SERVER_PORT=9020
COORDINATOR_HOST=127.0.0.1
COORDINATOR_PORT=9020

# ---------------------------------------------------------------------------
# Email - Mailpit (local testing)
# ---------------------------------------------------------------------------
# Mailpit UI: http://localhost:8025
# Magic links will appear in Mailpit AND webapp logs.
# If Trigger.dev doesn't pick up SMTP_HOST, check webapp logs instead:
#   docker compose logs -f webapp
#
# Trigger.dev only supports Resend for email (not raw SMTP).
# Without Resend configured, magic links print to webapp logs:
#   docker compose logs -f webapp
#
# To enable email delivery, sign up at resend.com and set:
FROM_EMAIL=
REPLY_TO_EMAIL=
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Access Control
# ---------------------------------------------------------------------------
# WHITELISTED_EMAILS="admin@yourdomain\.com|team@yourdomain\.com"
# ADMIN_EMAILS="admin@yourdomain\.com"
# AUTH_GITHUB_CLIENT_ID=
# AUTH_GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Registry (for deploying trigger tasks)
# ---------------------------------------------------------------------------
# DEPLOY_REGISTRY_HOST=docker.io
# DEPLOY_REGISTRY_NAMESPACE=your-dockerhub-username
# REGISTRY_HOST=${DEPLOY_REGISTRY_HOST}
# REGISTRY_NAMESPACE=${DEPLOY_REGISTRY_NAMESPACE}

# ---------------------------------------------------------------------------
# Docker Compose Overrides
# ---------------------------------------------------------------------------
WEBAPP_PUBLISH_IP=127.0.0.1
DOCKER_PUBLISH_IP=127.0.0.1

WEBAPP_HOST_PORT=3040
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6389
ELECTRIC_HOST_PORT=3061
# Image version pinning
TRIGGER_IMAGE_TAG=v3
POSTGRES_IMAGE_TAG=16
REDIS_IMAGE_TAG=7
ELECTRIC_IMAGE_TAG=latest
